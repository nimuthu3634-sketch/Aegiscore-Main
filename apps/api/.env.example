APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=postgresql+psycopg://aegiscore:aegiscore_dev_password@localhost:5432/aegiscore
JWT_SECRET_KEY=replace-with-a-development-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
WAZUH_BASE_URL=http://localhost:55000
WAZUH_USERNAME=
WAZUH_PASSWORD=
WAZUH_BEARER_TOKEN=
WAZUH_AUTH_MODE=basic
WAZUH_AUTH_ENDPOINT=/security/user/authenticate
WAZUH_ALERTS_PATH=/alerts
WAZUH_CONNECTOR_ENABLED=true
WAZUH_POLL_INTERVAL_SECONDS=30
WAZUH_TIMEOUT_SECONDS=10
WAZUH_RETRY_ATTEMPTS=2
WAZUH_RETRY_BACKOFF_SECONDS=1
WAZUH_VERIFY_TLS=true
WAZUH_CA_FILE=
WAZUH_PAGE_SIZE=200
WAZUH_MAX_PAGES_PER_CYCLE=5
WAZUH_OFFSET_PARAM=offset
WAZUH_SINCE_PARAM=since
WAZUH_TIMESTAMP_FIELD=timestamp
SURICATA_SOURCE=suricata
SURICATA_CONNECTOR_ENABLED=true
SURICATA_CONNECTOR_MODE=file_tail
SURICATA_EVE_FILE_PATH=/var/log/suricata/eve.json
SURICATA_POLL_INTERVAL_SECONDS=15
SURICATA_MAX_EVENTS_PER_CYCLE=250
SURICATA_RETRY_ATTEMPTS=2
SURICATA_RETRY_BACKOFF_SECONDS=1
SURICATA_FAIL_WHEN_SOURCE_MISSING=true
INGESTION_ALLOW_ASSET_AUTOCREATE=true
INGESTION_DEFAULT_ASSET_CRITICALITY=medium
DEV_SEED_ADMIN_USERNAME=admin
DEV_SEED_ADMIN_PASSWORD=AegisCore123!
DEV_SEED_ANALYST_USERNAME=analyst
DEV_SEED_ANALYST_PASSWORD=AegisCore123!
SCORING_STRATEGY=baseline
SCORING_BASELINE_VERSION=baseline_v1
SCORING_MODEL_PATH=/srv/ai/models/aegiscore-risk-priority-model.joblib
SCORING_MODEL_METADATA_PATH=/srv/ai/models/aegiscore-risk-priority-model.metadata.json
SCORING_MODEL_VERSION=untrained
AUTOMATED_RESPONSE_ALLOW_DESTRUCTIVE=false
AUTOMATED_RESPONSE_MAX_RETRIES=1
AUTOMATED_RESPONSE_BUILTIN_ADAPTERS_ENABLED=true
AUTOMATED_RESPONSE_LAB_ADAPTERS_ENABLED=false
AUTOMATED_RESPONSE_BLOCK_IP_BACKEND=ledger
AUTOMATED_RESPONSE_DISABLE_USER_BACKEND=ledger
AUTOMATED_RESPONSE_LEDGER_PATH=/tmp/aegiscore-response-ledger.jsonl
AUTOMATED_RESPONSE_HOST_TAG_PATH=/tmp/aegiscore-host-tags.jsonl
AUTOMATED_RESPONSE_ENABLE_HOST_TAG_WRITE=false
RESPONSE_ADAPTER_BLOCK_IP_SCRIPT=
RESPONSE_ADAPTER_DISABLE_USER_SCRIPT=
RESPONSE_ADAPTER_QUARANTINE_HOST_FLAG_SCRIPT=
RESPONSE_ADAPTER_CREATE_MANUAL_REVIEW_SCRIPT=
RESPONSE_ADAPTER_NOTIFY_ADMIN_SCRIPT=
NOTIFICATIONS_ENABLED=false
NOTIFICATIONS_MODE=log
NOTIFICATIONS_RISK_THRESHOLD=85
NOTIFICATIONS_INCIDENT_STATES=triaged,investigating,contained
NOTIFICATIONS_RESPONSE_STATUSES=warning,failed
NOTIFICATIONS_ADMIN_RECIPIENTS=admin@aegiscore.local
NOTIFICATIONS_SENDER=aegiscore@localhost
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
SMTP_USE_STARTTLS=false
SMTP_TIMEOUT_SECONDS=10
DB_CONNECT_MAX_ATTEMPTS=25
DB_CONNECT_BACKOFF_SECONDS=2
